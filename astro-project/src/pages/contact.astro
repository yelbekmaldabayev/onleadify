---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Консультация — Onleadify">
  <main class="min-h-screen bg-background relative overflow-hidden">
    <!-- Background effects -->
    <div class="contact-glow"></div>
    <div class="contact-grid"></div>
    
    <!-- Header -->
    <header class="fixed top-0 left-0 right-0 z-50 border-b border-border/50 bg-background/80 backdrop-blur-lg">
      <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
        <div class="flex h-16 items-center justify-between">
          <a href="/" class="flex items-center gap-2.5 group">
            <div class="w-10 h-10 transition-transform group-hover:scale-105">
              <svg viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-full h-full">
                <style>
                  @keyframes contactSpinCW {
                    from { transform: rotate(0deg); }
                    to { transform: rotate(360deg); }
                  }
                  @keyframes contactSpinCCW {
                    from { transform: rotate(0deg); }
                    to { transform: rotate(-360deg); }
                  }
                  .contact-white-orbit {
                    transform-origin: 20px 20px;
                    animation: contactSpinCW 10s linear infinite;
                  }
                  .contact-purple-orbit {
                    transform-origin: 20px 20px;
                    animation: contactSpinCCW 8s linear infinite;
                  }
                </style>
                <defs>
                  <filter id="contact-glow-white" x="-50%" y="-50%" width="200%" height="200%">
                    <feGaussianBlur stdDeviation="1" result="blur"/>
                    <feMerge><feMergeNode in="blur"/><feMergeNode in="SourceGraphic"/></feMerge>
                  </filter>
                  <filter id="contact-glow-purple" x="-50%" y="-50%" width="200%" height="200%">
                    <feGaussianBlur stdDeviation="1.5" result="blur"/>
                    <feMerge><feMergeNode in="blur"/><feMergeNode in="SourceGraphic"/></feMerge>
                  </filter>
                  <linearGradient id="contact-logo-gradient" x1="8" y1="8" x2="32" y2="32" gradientUnits="userSpaceOnUse">
                    <stop stop-color="#ffffff"/>
                    <stop offset="1" stop-color="#e4e4e7"/>
                  </linearGradient>
                  <linearGradient id="contact-logo-gradient-2" x1="2" y1="20" x2="38" y2="20" gradientUnits="userSpaceOnUse">
                    <stop stop-color="#a78bfa"/>
                    <stop offset="0.5" stop-color="#8b5cf6"/>
                    <stop offset="1" stop-color="#7c3aed"/>
                  </linearGradient>
                </defs>
                <ellipse class="contact-white-orbit" cx="20" cy="20" rx="14" ry="5" stroke="url(#contact-logo-gradient)" stroke-width="2" fill="none" filter="url(#contact-glow-white)" transform="rotate(60 20 20)"/>
                <ellipse class="contact-purple-orbit" cx="20" cy="20" rx="16" ry="6" stroke="url(#contact-logo-gradient-2)" stroke-width="2.5" fill="none" filter="url(#contact-glow-purple)" transform="rotate(-30 20 20)"/>
              </svg>
            </div>
            <span class="text-lg font-semibold text-foreground tracking-tight hidden sm:inline">Onleadify</span>
          </a>
          <a href="/" class="text-sm text-muted-foreground hover:text-foreground transition-colors flex items-center gap-1">
            <svg class="w-4 h-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
            <span class="hidden sm:inline">Назад на главную</span>
            <span class="sm:hidden">Назад</span>
          </a>
        </div>
      </div>
    </header>

    <div class="relative z-10 pt-32 pb-20 px-4 sm:px-6 lg:px-8">
      <div class="mx-auto max-w-xl">
        <!-- Header -->
        <div class="text-center mb-12 animate-fade-in">
          <div class="inline-flex items-center gap-2 rounded-full border border-border bg-secondary/80 backdrop-blur-sm px-4 py-1.5 mb-6">
            <span class="h-2 w-2 rounded-full bg-green-500 animate-pulse shadow-[0_0_8px_rgba(34,197,94,0.6)]"></span>
            <span class="text-sm text-muted-foreground">Свяжитесь с нами</span>
          </div>
          <h1 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-foreground mb-4">
            Обсудим ваш проект
          </h1>
          <p class="text-lg text-muted-foreground max-w-md mx-auto">
            Оставьте заявку и мы свяжемся с вами в течение 30 минут
          </p>
        </div>

        <!-- Form Card -->
        <div class="form-card rounded-2xl border border-border bg-card/50 backdrop-blur-sm p-8 sm:p-10 animate-fade-in-up">
          <form id="contact-form" class="space-y-6">
            <!-- Name -->
            <div class="form-group">
              <label for="name" class="block text-sm font-medium text-foreground mb-2">
                Ваше имя <span class="text-red-400">*</span>
              </label>
              <input
                type="text"
                id="name"
                name="name"
                required
                placeholder="Как к вам обращаться?"
                class="form-input w-full h-12 px-4 rounded-lg border border-border bg-secondary/50 text-foreground placeholder:text-muted-foreground focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary transition-all"
              />
            </div>

            <!-- Phone -->
            <div class="form-group">
              <label for="phone" class="block text-sm font-medium text-foreground mb-2">
                Номер телефона <span class="text-red-400">*</span>
              </label>
              <input
                type="tel"
                id="phone"
                name="phone"
                required
                placeholder="+7 (___) ___-__-__"
                class="form-input w-full h-12 px-4 rounded-lg border border-border bg-secondary/50 text-foreground placeholder:text-muted-foreground focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary transition-all"
              />
            </div>

            <!-- Telegram -->
            <div class="form-group">
              <label for="telegram" class="block text-sm font-medium text-foreground mb-2">
                Telegram ID <span class="text-muted-foreground font-normal">(необязательно)</span>
              </label>
              <div class="relative">
                <span class="absolute left-4 top-1/2 -translate-y-1/2 text-muted-foreground">@</span>
                <input
                  type="text"
                  id="telegram"
                  name="telegram"
                  placeholder="username"
                  class="form-input w-full h-12 pl-8 pr-4 rounded-lg border border-border bg-secondary/50 text-foreground placeholder:text-muted-foreground focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary transition-all"
                />
              </div>
            </div>

            <!-- Submit Button -->
            <button
              type="submit"
              class="submit-btn group relative w-full h-14 rounded-lg bg-foreground text-background font-medium text-base overflow-hidden transition-all duration-300"
            >
              <span class="relative z-10 flex items-center justify-center gap-2">
                Отправить заявку
                <svg class="w-5 h-5 transition-transform group-hover:translate-x-1" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
              </span>
            </button>
          </form>

          <!-- Divider -->
          <div class="relative my-8">
            <div class="absolute inset-0 flex items-center">
              <div class="w-full border-t border-border"></div>
            </div>
            <div class="relative flex justify-center text-sm">
              <span class="px-4 bg-card text-muted-foreground">или напишите напрямую</span>
            </div>
          </div>

          <!-- WhatsApp Button -->
          <a
            href="https://wa.me/77759894392"
            target="_blank"
            rel="noopener noreferrer"
            class="whatsapp-btn group flex flex-col sm:flex-row items-center justify-center gap-2 sm:gap-3 w-full h-auto py-4 sm:h-14 sm:py-0 rounded-lg border border-[#25D366]/30 bg-[#25D366]/10 text-[#25D366] font-medium text-base hover:bg-[#25D366]/20 hover:border-[#25D366]/50 transition-all duration-300"
          >
            <div class="flex items-center gap-2">
              <svg class="w-5 h-5 sm:w-6 sm:h-6" viewBox="0 0 24 24" fill="currentColor">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
              </svg>
              <span>Написать в WhatsApp</span>
            </div>
            <span class="text-sm opacity-70">+7 775 989 43 92</span>
          </a>
        </div>

        <!-- Trust badges -->
        <div class="mt-10 flex flex-col sm:flex-row flex-wrap items-center justify-center gap-4 sm:gap-6 text-sm text-muted-foreground animate-fade-in-up-delayed">
          <div class="flex items-center gap-2">
            <svg class="w-5 h-5 text-green-500 flex-shrink-0" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><path d="m9 11 3 3L22 4"/></svg>
            <span>Ответим за 30 минут</span>
          </div>
          <div class="flex items-center gap-2">
            <svg class="w-5 h-5 text-green-500 flex-shrink-0" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><path d="m9 11 3 3L22 4"/></svg>
            <span>Бесплатная консультация</span>
          </div>
          <div class="flex items-center gap-2">
            <svg class="w-5 h-5 text-green-500 flex-shrink-0" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><path d="m9 11 3 3L22 4"/></svg>
            <span>Без обязательств</span>
          </div>
        </div>
      </div>
    </div>

    <!-- Success Modal -->
    <div id="success-modal" class="fixed inset-0 z-50 hidden items-center justify-center p-4 bg-background/80 backdrop-blur-sm">
      <div class="success-card max-w-md w-full rounded-2xl border border-border bg-card p-8 text-center">
        <div class="w-16 h-16 mx-auto mb-6 rounded-full bg-green-500/20 flex items-center justify-center">
          <svg class="w-8 h-8 text-green-500" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><path d="m9 11 3 3L22 4"/></svg>
        </div>
        <h3 class="text-2xl font-bold text-foreground mb-2">Заявка отправлена!</h3>
        <p class="text-muted-foreground mb-6">Мы свяжемся с вами в ближайшее время</p>
        <a href="/" class="inline-flex items-center justify-center h-12 px-8 rounded-lg bg-foreground text-background font-medium transition-all hover:opacity-90">
          Вернуться на главную
        </a>
      </div>
    </div>
  </main>
</Layout>

<style>
  .contact-glow {
    position: absolute;
    top: 10%;
    left: 50%;
    transform: translateX(-50%);
    width: 800px;
    height: 500px;
    background: radial-gradient(ellipse, rgba(120, 119, 198, 0.12) 0%, transparent 70%);
    pointer-events: none;
  }
  
  .contact-grid {
    position: absolute;
    inset: 0;
    background-image: 
      linear-gradient(rgba(255,255,255,0.015) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255,255,255,0.015) 1px, transparent 1px);
    background-size: 60px 60px;
    mask-image: radial-gradient(ellipse 80% 60% at 50% 30%, black 20%, transparent 100%);
    pointer-events: none;
  }
  
  .form-card {
    box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.25);
  }
  
  .form-input:focus {
    border-color: rgba(120, 119, 198, 0.5);
    box-shadow: 0 0 0 3px rgba(120, 119, 198, 0.1);
  }
  
  .form-group {
    opacity: 0;
    animation: fadeInUp 0.5s ease-out forwards;
  }
  
  .form-group:nth-child(1) { animation-delay: 0.1s; }
  .form-group:nth-child(2) { animation-delay: 0.2s; }
  .form-group:nth-child(3) { animation-delay: 0.3s; }
  
  .submit-btn {
    box-shadow: 0 4px 14px rgba(0, 0, 0, 0.25);
  }
  
  .submit-btn::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, rgba(255,255,255,0.1) 0%, transparent 50%);
    opacity: 0;
    transition: opacity 0.3s ease;
  }
  
  .submit-btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(0, 0, 0, 0.3);
  }
  
  .submit-btn:hover::before {
    opacity: 1;
  }
  
  .whatsapp-btn:hover {
    box-shadow: 0 0 20px rgba(37, 211, 102, 0.2);
  }
  
  .animate-fade-in {
    animation: fadeIn 0.6s ease-out forwards;
  }
  
  .animate-fade-in-up {
    opacity: 0;
    animation: fadeInUp 0.6s ease-out 0.2s forwards;
  }
  
  .animate-fade-in-up-delayed {
    opacity: 0;
    animation: fadeInUp 0.6s ease-out 0.6s forwards;
  }
  
  @keyframes fadeIn {
    from { opacity: 0; }
    to { opacity: 1; }
  }
  
  @keyframes fadeInUp {
    from { 
      opacity: 0; 
      transform: translateY(20px);
    }
    to { 
      opacity: 1; 
      transform: translateY(0);
    }
  }
  
  .success-card {
    animation: scaleIn 0.3s ease-out forwards;
  }
  
  @keyframes scaleIn {
    from {
      opacity: 0;
      transform: scale(0.95);
    }
    to {
      opacity: 1;
      transform: scale(1);
    }
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const form = document.getElementById('contact-form') as HTMLFormElement;
    const modal = document.getElementById('success-modal');
    
    form?.addEventListener('submit', (e) => {
      e.preventDefault();
      
      // Get form data
      const formData = new FormData(form);
      const data = {
        name: formData.get('name'),
        phone: formData.get('phone'),
        telegram: formData.get('telegram')
      };
      
      console.log('Form submitted:', data);
      
      // Show success modal
      if (modal) {
        modal.classList.remove('hidden');
        modal.classList.add('flex');
      }
      
      // Reset form
      form.reset();
    });
    
    // Phone input formatting
    const phoneInput = document.getElementById('phone') as HTMLInputElement;
    phoneInput?.addEventListener('input', (e) => {
      let value = (e.target as HTMLInputElement).value.replace(/\D/g, '');
      if (value.length > 0) {
        if (value[0] === '8') {
          value = '7' + value.slice(1);
        }
        if (value[0] !== '7') {
          value = '7' + value;
        }
        let formatted = '+7';
        if (value.length > 1) {
          formatted += ' (' + value.slice(1, 4);
        }
        if (value.length > 4) {
          formatted += ') ' + value.slice(4, 7);
        }
        if (value.length > 7) {
          formatted += '-' + value.slice(7, 9);
        }
        if (value.length > 9) {
          formatted += '-' + value.slice(9, 11);
        }
        (e.target as HTMLInputElement).value = formatted;
      }
    });
  });
</script>
