---

<section id="services" class="py-16 sm:py-24">
  <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-12 sm:mb-16 section-header">
      <span class="inline-block text-xs font-medium text-muted-foreground uppercase tracking-widest mb-4">Наши услуги</span>
      <h2 class="text-2xl sm:text-3xl md:text-4xl lg:text-5xl font-bold text-foreground text-balance px-2">
        Комплексные решения для вашего бизнеса
      </h2>
      <p class="mt-4 sm:mt-6 text-base sm:text-lg text-muted-foreground max-w-2xl mx-auto leading-relaxed px-2">
        От идеи до реализации — мы создаём цифровые продукты, которые работают на результат
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-4 sm:gap-6 services-grid">
      {services.map((service, idx) => (
        <div
          class={`service-card group rounded-xl border border-border bg-card p-6 sm:p-8 transition-all duration-500 ${idx === 1 ? 'md:-translate-y-4' : ''}`}
          data-index={idx}
        >
          <span class="inline-block text-xs font-medium text-muted-foreground tracking-widest mb-3 sm:mb-4">
            {service.category}
          </span>
          <h3 class="text-lg sm:text-xl font-semibold text-foreground mb-2 sm:mb-3">
            {service.title}
          </h3>
          <p class="text-muted-foreground text-sm mb-6 sm:mb-8 leading-relaxed">
            {service.description}
          </p>

          <ul class="space-y-3 sm:space-y-4">
            {service.items.map((item, itemIdx) => (
              <li class="flex items-center gap-3 sm:gap-4 service-item" data-item-index={itemIdx}>
                <div class="flex h-9 w-9 sm:h-10 sm:w-10 items-center justify-center rounded-lg bg-secondary border border-border icon-container transition-all duration-300 flex-shrink-0">
                  <span class="text-foreground" set:html={icons[item.icon]} />
                </div>
                <span class="text-sm text-foreground">{item.name}</span>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .section-header {
    opacity: 0;
    transform: translateY(30px);
    transition: all 0.8s ease-out;
  }
  
  .section-header.visible {
    opacity: 1;
    transform: translateY(0);
  }
  
  .service-card {
    opacity: 0;
    transform: translateY(40px);
    transition: all 0.6s ease-out, border-color 0.3s ease, box-shadow 0.3s ease;
    position: relative;
    overflow: hidden;
  }
  
  /* Subtle gradient overlay on active */
  .service-card::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, rgba(120, 119, 198, 0.05) 0%, transparent 50%);
    opacity: 0;
    transition: opacity 0.5s ease;
    pointer-events: none;
  }
  
  .service-card.active::before,
  .service-card:hover::before {
    opacity: 1;
  }
  
  /* Corner accent */
  .service-card::after {
    content: '';
    position: absolute;
    top: 0;
    right: 0;
    width: 60px;
    height: 60px;
    background: radial-gradient(circle at top right, rgba(120, 119, 198, 0.15) 0%, transparent 70%);
    opacity: 0;
    transition: opacity 0.5s ease;
    pointer-events: none;
  }
  
  .service-card.active::after,
  .service-card:hover::after {
    opacity: 1;
  }
  
  .service-card.visible {
    opacity: 1;
    transform: translateY(0);
  }
  
  .service-card[data-index="1"].visible {
    transform: translateY(-16px);
  }
  
  .service-card.active {
    border-color: rgba(138, 138, 138, 0.5);
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.2), 0 0 0 1px rgba(120, 119, 198, 0.1);
  }
  
  .service-card.active .icon-container {
    background: rgba(120, 119, 198, 0.15);
    border-color: rgba(120, 119, 198, 0.3);
    box-shadow: 0 0 20px rgba(120, 119, 198, 0.2);
  }
  
  .service-item {
    opacity: 0;
    transform: translateX(-10px);
    transition: all 0.4s ease-out;
  }
  
  .service-card.visible .service-item {
    opacity: 1;
    transform: translateX(0);
  }
  
  .service-card.visible .service-item[data-item-index="0"] { transition-delay: 0.1s; }
  .service-card.visible .service-item[data-item-index="1"] { transition-delay: 0.2s; }
  .service-card.visible .service-item[data-item-index="2"] { transition-delay: 0.3s; }
  
  .service-card:hover {
    border-color: rgba(138, 138, 138, 0.5);
    transform: translateY(-4px);
  }
  
  .service-card[data-index="1"]:hover {
    transform: translateY(-20px);
  }
  
  .icon-container {
    transition: all 0.4s ease;
  }
  
  .service-card:hover .icon-container {
    transform: scale(1.05);
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const cards = document.querySelectorAll('.service-card');
    const header = document.querySelector('.section-header');
    let activeIndex = 0;
    let cycleInterval: ReturnType<typeof setInterval>;
    
    // Intersection observer for entrance animations
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          if (entry.target.classList.contains('section-header')) {
            entry.target.classList.add('visible');
          }
          if (entry.target.classList.contains('service-card')) {
            const index = parseInt((entry.target as HTMLElement).dataset.index || '0');
            setTimeout(() => {
              entry.target.classList.add('visible');
            }, index * 150);
          }
        }
      });
    }, { threshold: 0.2 });
    
    if (header) observer.observe(header);
    cards.forEach(card => observer.observe(card));
    
    // Auto-cycling highlight effect
    function cycleCards() {
      cards.forEach(card => card.classList.remove('active'));
      cards[activeIndex].classList.add('active');
      activeIndex = (activeIndex + 1) % cards.length;
    }
    
    // Start cycling when cards are in view
    const cycleObserver = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          cycleInterval = setInterval(cycleCards, 2500);
          cycleCards();
        } else {
          clearInterval(cycleInterval);
          cards.forEach(card => card.classList.remove('active'));
        }
      });
    }, { threshold: 0.3 });
    
    const servicesGrid = document.querySelector('.services-grid');
    if (servicesGrid) cycleObserver.observe(servicesGrid);
    
    // Pause cycling on hover
    cards.forEach(card => {
      card.addEventListener('mouseenter', () => {
        clearInterval(cycleInterval);
        cards.forEach(c => c.classList.remove('active'));
        card.classList.add('active');
      });
      
      card.addEventListener('mouseleave', () => {
        cycleInterval = setInterval(cycleCards, 2500);
      });
    });
  });
</script>
