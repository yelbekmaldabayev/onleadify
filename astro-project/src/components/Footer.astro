---
const footerLinks = {
  services: [
    { href: "#", label: "Веб-разработка" },
    { href: "#", label: "AI-чатботы" },
    { href: "#", label: "CRM-системы" },
    { href: "#", label: "Автоматизация" },
  ],
  company: [
    { href: "#about", label: "О компании" },
    { href: "#cases", label: "Кейсы" },
    { href: "#", label: "Блог" },
    { href: "#contact", label: "Контакты" },
  ],
}
---

<footer class="border-t border-border bg-card/50">
  <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8 py-16">
    <div class="grid grid-cols-2 md:grid-cols-4 gap-12">
      <div class="col-span-2 md:col-span-1">
        <a href="/" class="flex items-center gap-2.5 mb-6 group">
          <div class="w-10 h-10 transition-transform group-hover:scale-105">
            <svg viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-full h-full">
              <style>
                @keyframes footerSpinCW {
                  from { transform: rotate(0deg); }
                  to { transform: rotate(360deg); }
                }
                @keyframes footerSpinCCW {
                  from { transform: rotate(0deg); }
                  to { transform: rotate(-360deg); }
                }
                .footer-white-orbit {
                  transform-origin: 20px 20px;
                  animation: footerSpinCW 10s linear infinite;
                }
                .footer-purple-orbit {
                  transform-origin: 20px 20px;
                  animation: footerSpinCCW 8s linear infinite;
                }
              </style>
              <defs>
                <filter id="footer-glow-white" x="-50%" y="-50%" width="200%" height="200%">
                  <feGaussianBlur stdDeviation="1" result="blur"/>
                  <feMerge><feMergeNode in="blur"/><feMergeNode in="SourceGraphic"/></feMerge>
                </filter>
                <filter id="footer-glow-purple" x="-50%" y="-50%" width="200%" height="200%">
                  <feGaussianBlur stdDeviation="1.5" result="blur"/>
                  <feMerge><feMergeNode in="blur"/><feMergeNode in="SourceGraphic"/></feMerge>
                </filter>
                <linearGradient id="footer-logo-gradient" x1="8" y1="8" x2="32" y2="32" gradientUnits="userSpaceOnUse">
                  <stop stop-color="#ffffff"/>
                  <stop offset="1" stop-color="#e4e4e7"/>
                </linearGradient>
                <linearGradient id="footer-logo-gradient-2" x1="2" y1="20" x2="38" y2="20" gradientUnits="userSpaceOnUse">
                  <stop stop-color="#a78bfa"/>
                  <stop offset="0.5" stop-color="#8b5cf6"/>
                  <stop offset="1" stop-color="#7c3aed"/>
                </linearGradient>
              </defs>
              <ellipse class="footer-white-orbit" cx="20" cy="20" rx="14" ry="5" stroke="url(#footer-logo-gradient)" stroke-width="2" fill="none" filter="url(#footer-glow-white)" transform="rotate(60 20 20)"/>
              <ellipse class="footer-purple-orbit" cx="20" cy="20" rx="16" ry="6" stroke="url(#footer-logo-gradient-2)" stroke-width="2.5" fill="none" filter="url(#footer-glow-purple)" transform="rotate(-30 20 20)"/>
            </svg>
          </div>
          <span class="text-lg font-semibold text-foreground tracking-tight">Onleadify</span>
        </a>
        <p class="text-sm text-muted-foreground leading-relaxed">
          Веб-студия и автоматизация для бизнеса
        </p>
      </div>

      <div>
        <h4 class="font-semibold text-foreground mb-6">Услуги</h4>
        <ul class="space-y-3">
          {footerLinks.services.map((link) => (
            <li>
              <a
                href={link.href}
                class="text-sm text-muted-foreground hover:text-foreground transition-colors"
              >
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <div>
        <h4 class="font-semibold text-foreground mb-6">Компания</h4>
        <ul class="space-y-3">
          {footerLinks.company.map((link) => (
            <li>
              <a
                href={link.href}
                class="text-sm text-muted-foreground hover:text-foreground transition-colors"
              >
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <div>
        <h4 class="font-semibold text-foreground mb-6">Контакты</h4>
        <ul class="space-y-3 text-sm text-muted-foreground">
          <li class="hover:text-foreground transition-colors cursor-pointer">yelbekmaldabayev@gmail.com</li>
          <li class="hover:text-foreground transition-colors cursor-pointer">+7 707 324 91 07</li>
          <li>Казахстан, Алматы</li>
        </ul>
      </div>
    </div>

    <div class="mt-12 sm:mt-16 pt-8 border-t border-border flex flex-col sm:flex-row items-center justify-between gap-4 text-center sm:text-left">
      <p class="text-sm text-muted-foreground">
        © 2026 Onleadify. Все права защищены.
      </p>
      <div class="flex flex-col sm:flex-row items-center gap-4 sm:gap-8">
        <a href="#" class="text-sm text-muted-foreground hover:text-foreground transition-colors">
          Политика конфиденциальности
        </a>
        <a href="#" class="text-sm text-muted-foreground hover:text-foreground transition-colors">
          Оферта
        </a>
      </div>
    </div>
  </div>
</footer>
