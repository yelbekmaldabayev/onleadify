<section id="contact" class="py-16 sm:py-24 relative overflow-hidden">
  <!-- Background glow -->
  <div class="cta-glow"></div>
  
  <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8 relative z-10">
    <div class="cta-card relative rounded-xl sm:rounded-2xl overflow-hidden border border-border bg-card/80 backdrop-blur-sm">
      <!-- Corner accents -->
      <div class="absolute top-0 left-0 w-20 h-20 sm:w-32 sm:h-32 bg-gradient-to-br from-purple-500/10 to-transparent"></div>
      <div class="absolute bottom-0 right-0 w-20 h-20 sm:w-32 sm:h-32 bg-gradient-to-tl from-purple-500/10 to-transparent"></div>
      
      <div class="px-5 py-12 sm:px-12 sm:py-24 text-center relative">
        <h2 class="text-2xl sm:text-3xl md:text-4xl lg:text-5xl font-bold text-foreground mb-4 sm:mb-6 text-balance cta-title px-2">
          Готовы вывести бизнес на новый уровень?
        </h2>
        <p class="text-base sm:text-lg text-muted-foreground max-w-2xl mx-auto mb-8 sm:mb-10 leading-relaxed px-2">
          Обсудим ваш проект и предложим оптимальное решение. Консультация бесплатная.
        </p>
        <div class="flex flex-col sm:flex-row items-center justify-center gap-3 sm:gap-4">
          <a href="/contact" class="group cta-btn-primary relative inline-flex items-center justify-center w-full sm:w-auto h-12 sm:h-14 px-8 sm:px-10 text-base bg-foreground text-background font-medium gap-2 rounded-xl transition-all duration-300 overflow-hidden">
            <span class="relative z-10 flex items-center gap-2">
              Обсудить проект
              <svg class="transition-transform group-hover:translate-x-1" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
            </span>
          </a>
          <a href="https://wa.me/77759894392" target="_blank" rel="noopener noreferrer" class="group inline-flex items-center justify-center w-full sm:w-auto h-12 sm:h-14 px-8 sm:px-10 text-base border border-[#25D366]/30 bg-[#25D366]/10 text-[#25D366] hover:bg-[#25D366]/20 hover:border-[#25D366]/50 gap-2 sm:gap-3 rounded-xl transition-all duration-300">
            <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
            </svg>
            <span>WhatsApp</span>
          </a>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .cta-glow {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 600px;
    height: 400px;
    background: radial-gradient(ellipse, rgba(120, 119, 198, 0.1) 0%, transparent 70%);
    pointer-events: none;
  }
  
  .cta-card {
    box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.25);
    opacity: 0;
    transform: translateY(30px);
    transition: all 0.8s ease-out;
  }
  
  .cta-card.visible {
    opacity: 1;
    transform: translateY(0);
  }
  
  .cta-btn-primary {
    box-shadow: 0 4px 14px rgba(0, 0, 0, 0.25);
  }
  
  .cta-btn-primary::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, rgba(255,255,255,0.1) 0%, transparent 50%);
    opacity: 0;
    transition: opacity 0.3s ease;
  }
  
  .cta-btn-primary:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 25px rgba(0, 0, 0, 0.3);
  }
  
  .cta-btn-primary:hover::before {
    opacity: 1;
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const ctaCard = document.querySelector('.cta-card');
    
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('visible');
        }
      });
    }, { threshold: 0.2 });
    
    if (ctaCard) observer.observe(ctaCard);
  });
</script>
